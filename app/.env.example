# Public frontend configuration. All values here are public (RPC URL, network
# passphrase, deployed contract addresses). No private keys, ever.
# Copy to .env.local and fill in the deployed addresses.

NEXT_PUBLIC_SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_SIMULATION_SOURCE_ADDRESS="GBGHELMOABS7WCYOMJTWQRGQ6VZYLYXXMLE7JJAHJ6I4WW7FMJSDERN3"
NEXT_PUBLIC_MARKET_ID="blend-usdc-q3"
NEXT_PUBLIC_TOKEN_DECIMALS="7"

NEXT_PUBLIC_SY_ADDRESS=""
NEXT_PUBLIC_PT_ADDRESS=""
NEXT_PUBLIC_YT_ADDRESS=""
NEXT_PUBLIC_TOKENIZER_ADDRESS=""
NEXT_PUBLIC_MARKET_ADDRESS=""

# Hosted demo runner configuration for production Vercel.
# DEMO_RUNNER_API_URL points to the Render Docker service, for example:
# https://sidereal-demo-runner.onrender.com
NEXT_PUBLIC_DEMO_RUNNER_ENABLED="0"
DEMO_RUNNER_API_URL=""
DEMO_RUNNER_TOKEN=""
